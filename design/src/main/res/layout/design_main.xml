<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable name="self" type="com.github.kr328.clash.design.MainDesign" />
        <variable name="clashRunning" type="boolean" />
        <import type="android.view.View" />
        <import type="com.github.kr328.clash.design.MainDesign.Request" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/telegood_bg_dark"
        android:animateLayoutChanges="true">

        <View
            android:id="@+id/glow_background"
            android:layout_width="140dp"
            android:layout_height="340dp"
            android:background="@drawable/bg_pill_halos"
            android:alpha="0"
            android:scaleX="0.85"
            android:scaleY="0.85"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/main_pill_button"
            android:layout_width="140dp"
            android:layout_height="340dp"
            android:orientation="vertical"
            android:gravity="center"
            android:onClick="@{() -> self.request(Request.ToggleStatus)}"
            android:clickable="true"
            android:focusable="true"
            android:elevation="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:checked="@{clashRunning}"
                android:clickable="false"
                android:focusable="false"
                android:text=""
                android:textOn=""
                android:textOff=""
                app:showText="false"
                app:thumbTint="#FFFFFF" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <androidx.cardview.widget.CardView
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent"
                android:alpha="@{clashRunning ? 1.0f : 0.3f}">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_clash" />
            </androidx.cardview.widget.CardView>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <FrameLayout
                android:id="@+id/flag_container"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginBottom="32dp"
                android:gravity="center"
                android:alpha="@{clashRunning ? 1.0f : 0.4f}">

                <TextView
                    android:id="@+id/location_indicator"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="&#x1F30D;"
                    android:textSize="28sp"
                    />

            </FrameLayout>

        </LinearLayout>

        <ImageView
            android:id="@+id/btn_proxy"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_baseline_apps"
            app:tint="@color/telegood_icon_off"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:onClick="@{() -> self.request(Request.OpenProxy)}"
            android:visibility="@{clashRunning ? View.VISIBLE : View.GONE}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginBottom="40dp"
            android:layout_marginStart="40dp"/>

        <ImageView
            android:id="@+id/btn_health_check"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_baseline_flash_on"
            app:tint="@color/telegood_icon_off"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:onClick="@{() -> self.request(Request.RequestUrlTest)}"
            android:visibility="@{clashRunning ? View.VISIBLE : View.GONE}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="40dp"/>

        <ImageView
            android:id="@+id/btn_settings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_baseline_settings"
            app:tint="@color/telegood_icon_off"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:onClick="@{() -> self.request(Request.OpenSettings)}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="40dp"
            android:layout_marginEnd="40dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>